<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_order_form_view_inherit_sales_order_double_approval"
            model="ir.ui.view">
        <field name="name">sale.order.form.view.inherit.sales.order.double.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_quotation_send']" position="after">
                <!-- Approve Button -->
                <!-- Visible ONLY when state is 'to_approve' -->
                <!-- Visible to Sales Managers OR Sale Order Approvers -->
                <!-- REPLACE 'sales_order_double_approval' with your actual module folder name -->
                <button name="button_approve" string="Approve"
                        class="oe_highlight" type="object"
                        invisible="state != 'to_approve'"
                        groups="sales_team.group_sale_manager,sales_order_double_approval.group_sale_order_approver"/>
                
                <!-- Cancel Button -->
                <button name="action_cancel" string="Cancel"
                        class="btn-secondary" type="object"
                        invisible="state != 'to_approve'"
                        groups="sales_team.group_sale_manager,sales_order_double_approval.group_sale_order_approver"/>
            </xpath>
            
            <!-- Optional: Hide the standard 'Confirm' button when in 'to_approve' state to avoid confusion -->
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state not in ('draft', 'sent')</attribute>
            </xpath>
        </field>
    </record>
</odoo>