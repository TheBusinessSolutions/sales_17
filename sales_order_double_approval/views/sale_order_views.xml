<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_order_form_view_inherit_sales_order_double_approval"
            model="ir.ui.view">
        <field name="name">sale.order.form.view.inherit.sales.order.double.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_quotation_send']" position="after">
                <!-- Add both groups here: Sales Manager AND Sale Order Approver -->
                <!-- REPLACE 'your_module_name' with your actual module folder name -->
                <button name="button_approve" string="Approve"
                        class="oe_highlight" type="object"
                        invisible="state != 'to_approve'"
                        groups="sales_team.group_sale_manager,your_module_name.group_sale_order_approver"/>
                
                <button name="action_cancel" string="Cancel"
                        class="oe_highlight" type="object"
                        invisible="state != 'to_approve'"
                        groups="sales_team.group_sale_manager,your_module_name.group_sale_order_approver"/>
            </xpath>
        </field>
    </record>
</odoo>