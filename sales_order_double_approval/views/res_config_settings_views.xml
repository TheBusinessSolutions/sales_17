<odoo>
    <record id="res_config_settings_form_view_inherit_sales_order_double_approval"
            model="ir.ui.view">
        <field name="name">res.config.settings.form.view.inherit.sales.order.double.approval</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']//block[@id='pricing_setting_container']" position="after">
                <block title="Sale Order Approval" id="sale_order_approval_setting_container">
                    <setting id="so_approval" help="Request managers/approvers to approve orders above a minimum amount">
                        <field name="so_approval"/>
                        <div class="content-group" invisible="not so_approval">
                            <div class="mt16">
                                <label for="so_min_amount"/>
                                <field name="so_min_amount" style="margin-left: 10px;"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>