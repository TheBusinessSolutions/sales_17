<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="form_sale_order_approver" model="ir.ui.view">
        <field name="name">sale.order_approver</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Add hidden fields for logic -->
            <field name="authorized_transaction_ids" position="after">
                <field name="can_confirm_order" invisible="1"/>
                <field name="approval_status" invisible="1"/>
                <field name="next_approver_name" invisible="1"/>
            </field>

            <!-- Add status display in header -->
            <xpath expr="//header" position="inside">
                <div class="d-flex align-items-center mt-2 ms-2"
                     invisible="not approval_status">

                    <span class="badge bg-warning text-dark me-2">
                        <i class="fa fa-clock-o"/>
                        <field name="approval_status" readonly="1"/>
                    </span>

                    <span class="text-muted small"
                          invisible="not next_approver_name">
                        Next:
                        <field name="next_approver_name" readonly="1"/>
                    </span>

                </div>
            </xpath>

            <!-- First confirm button (Draft) -->
            <xpath expr="//button[@name='action_confirm'][1]" position="attributes">
                <attribute name="invisible">
                    state != 'draft' or not can_confirm_order
                </attribute>
            </xpath>

            <!-- Second confirm button (Sent) -->
            <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name="invisible">
                    state != 'sent' or not can_confirm_order
                </attribute>
            </xpath>

            <!-- Approvers tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Approvers">
                    <field name="sale_approver_line">
                        <tree decoration-success="approved_order"
                              create="0" delete="0" edit="0">
                            <field name="sequence" invisible="1"/>
                            <field name="approved_order" invisible="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="approved_order"
                                   widget="boolean_toggle"
                                   readonly="1"/>
                        </tree>

                        <form>
                            <group>
                                <field name="user_id"
                                       readonly="1"
                                       options="{'no_open': True}"/>
                                <field name="approved_order" readonly="1"/>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>

        <!-- ✅ Tree View: Add Approval Status Column -->
        <record id="view_sale_order_tree_approval_status" model="ir.ui.view">
            <field name="name">sale.order.tree.approval.status</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="after">
                    <field name="approval_status" 
                        string="حالة الموافقة" 
                        optional="show"
                        decoration-warning="approval_status and 'Pending' in approval_status"
                        decoration-success="approval_status and 'Fully' in approval_status"/>
                </xpath>
            </field>
        </record>
        </field>
    </record>
        <!-- ✅ RECORD 2: Tree View Inheritance (SEPARATE, at same level) -->
    <record id="view_sale_order_tree_approval_status" model="ir.ui.view">
        <field name="name">sale.order.tree.approval.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="approval_status" 
                       string="حالة الموافقة" 
                       optional="show"
                       decoration-warning="approval_status and 'Pending' in approval_status"
                       decoration-success="approval_status and 'Fully' in approval_status"/>
            </xpath>
        </field>
    </record>
</odoo>