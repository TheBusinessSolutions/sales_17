<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit_separate_cols" inherit_id="sale.report_saleorder_document">
        
        <xpath expr="//th[@name='th_description']" position="before">
            <t t-if="doc.company_id.print_product_name">
                <th name="th_product_name" class="text-start">Product Name</th>
            </t>
        </xpath>

        <xpath expr="//th[@name='th_description']" position="attributes">
            <attribute name="t-if">doc.company_id.print_product_description</attribute>
        </xpath>

        <xpath expr="//td[@name='td_name']" position="before">
            <t t-if="doc.company_id.print_product_name">
                <td name="td_product_name">
                    <span t-if="line.product_id" t-field="line.product_id.name"/>
                </td>
            </t>
        </xpath>

        <xpath expr="//td[@name='td_name']" position="attributes">
            <attribute name="t-if">doc.company_id.print_product_description or (not doc.company_id.print_product_name and not doc.company_id.print_product_description)</attribute>
        </xpath>

        <xpath expr="//td[@name='td_section_line']" position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>
        <xpath expr="//td[@name='td_note_line']" position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>

    </template>
</odoo>