<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_sale_display" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale.display</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='order_default_values']" position="after">
                <setting id="print_description_settings" string="Report Content" help="Choose what appears in the Description column of the Quotation PDF">
                    <div class="content-group">
                        <div class="row">
                            <field name="print_product_name" class="col-lg-1 ml16"/>
                            <label for="print_product_name" class="col-lg-10"/>
                        </div>
                        <div class="row">
                            <field name="print_product_description" class="col-lg-1 ml16"/>
                            <label for="print_product_description" class="col-lg-10"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>