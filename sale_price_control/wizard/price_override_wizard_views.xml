<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_price_override_wizard_form" model="ir.ui.view">
        <field name="name">price.override.wizard.form</field>
        <field name="model">price.override.wizard</field>
        <field name="arch" type="xml">
            <form string="Price Override Authorization">
                <group>
                    <div colspan="2" class="alert alert-warning" role="alert">
                        <strong>⚠ Warning:</strong>
                        The following order lines have prices below cost.
                        Enter your authorization password to confirm this order.
                    </div>
                    <field name="line_info" widget="text" nolabel="1" colspan="2"
                           style="font-family: monospace; color: #dc3545; font-weight: bold;
                                  min-height: 60px; background-color: #fff3cd; padding: 10px;
                                  border-radius: 4px;"/>
                    <field name="password" password="True" required="1"
                           placeholder="Enter your price override password..."/>
                    <field name="sale_order_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_authorize_and_confirm"
                            string="🔓 Authorize &amp; Confirm Order"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
