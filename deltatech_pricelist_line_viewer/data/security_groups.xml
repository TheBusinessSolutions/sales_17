<?xml version="1.0" ?>
<odoo noupdate="1">
        <record model="res.groups" id="group_user_permit_prilist_edit_access">
            <field name="name">Permit pricelist editing</field>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
        </record>

        <record id="access_pricelist_editing" model="ir.model.access">
            <field name="name">product.pricelist editing</field>
            <field name="model_id" ref="product.model_product_pricelist" />
            <field name="group_id" ref="group_user_permit_prilist_edit_access" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="1" />
            <field name="perm_unlink" eval="1" />
        </record>
        <record id="access_pricelist_item_editing" model="ir.model.access">
            <field name="name">product.pricelist.item editing</field>
            <field name="model_id" ref="product.model_product_pricelist_item" />
            <field name="group_id" ref="group_user_permit_prilist_edit_access" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="1" />
            <field name="perm_unlink" eval="1" />
        </record>
</odoo>
