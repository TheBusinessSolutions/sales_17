<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_tree_with_discount_fields" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.discount.fields</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="total_discount" string="Total Discount"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_tree_with_discount_fields" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.discount.fields</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="total_discount" string="Total Discount"/>
            </xpath>
        </field>
    </record>


</odoo>