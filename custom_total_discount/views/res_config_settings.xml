<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.discount</field>
        <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
                <xpath expr="//block[@id='product_general_settings']" position="before">
                <block title="Discount Settings" id="discount_settings">
                    <setting string="Apply Discount:">
                        <div class="content-group">
                            <div class="row mt8">
                                <label for="discount_application" class="col-lg-5 o_light_label" string="Discount Application"/>
                                <field name="discount_application" field_id="discount_application_0"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>