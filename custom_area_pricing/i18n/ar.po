msgid "Pricing Based Cost Rate"
msgstr "سعر التكلفة القائم على التسعير"

msgid "Pricing Based Cost Rates"
msgstr "أسعار التكلفة القائمة على التسعير"

msgid "Pricing Based Cost"
msgstr "التكلفة القائمة على التسعير"

msgid "Pricing Based Cost (per m²)"
msgstr "التكلفة القائمة على التسعير (لكل م²)"

msgid "Reference"
msgstr "المرجع"

msgid "Effective Date"
msgstr "تاريخ السريان"

msgid "Currency"
msgstr "العملة"

msgid "Product Category"
msgstr "فئة المنتج"

msgid "Notes"
msgstr "ملاحظات"

msgid "Status"
msgstr "الحالة"

msgid "Draft"
msgstr "مسودة"

msgid "Applied"
msgstr "مُطبَّق"

msgid "Apply Rate"
msgstr "تطبيق السعر"

msgid "Reset to Draft"
msgstr "إعادة إلى المسودة"

msgid "Products Updated"
msgstr "المنتجات المحدَّثة"

msgid "Affected Products"
msgstr "المنتجات المتأثرة"

msgid "Affected Products – %s"
msgstr "المنتجات المتأثرة – %s"

msgid "Product"
msgstr "المنتج"

msgid "Price Before"
msgstr "السعر قبل التغيير"

msgid "New Price"
msgstr "السعر الجديد"

msgid "Difference"
msgstr "الفرق"

msgid "Enable Area-Based Pricing"
msgstr "تفعيل التسعير القائم على المساحة"

msgid "Use Area Pricing"
msgstr "استخدام التسعير بالمساحة"

msgid "Default Width (m)"
msgstr "العرض الافتراضي (م)"

msgid "Default Height (m)"
msgstr "الارتفاع الافتراضي (م)"

msgid "Area Pricing"
msgstr "التسعير بالمساحة"

msgid "Width (m)"
msgstr "العرض (م)"

msgid "Height (m)"
msgstr "الارتفاع (م)"

msgid "Area (m²)"
msgstr "المساحة (م²)"

msgid "W (m)"
msgstr "ع (م)"

msgid "H (m)"
msgstr "ط (م)"

msgid "Rate/m²"
msgstr "السعر/م²"

msgid "Rate Used (per m²)"
msgstr "السعر المُستخدَم (لكل م²)"

msgid "Area Priced"
msgstr "مسعَّر بالمساحة"

msgid "Recalculate Area Prices"
msgstr "إعادة حساب أسعار المساحة"

msgid "Applied Cost Rate"
msgstr "سعر التكلفة المُطبَّق"

msgid "Prices Recalculated"
msgstr "تمت إعادة حساب الأسعار"

msgid "%d line(s) refreshed to current pricing."
msgstr "تم تحديث %d سطر/أسطر وفق التسعير الحالي."

msgid "You can only recalculate prices on draft quotations."
msgstr "يمكن إعادة حساب الأسعار فقط على عروض الأسعار في حالة المسودة."

msgid "No area-priced products found on this quotation."
msgstr "لا توجد منتجات مسعَّرة بالمساحة في عرض الأسعار هذا."

msgid "This rate has already been applied."
msgstr "تم تطبيق هذا السعر مسبقاً."

msgid "Pricing Based Cost rate must be greater than zero."
msgstr "يجب أن يكون سعر التكلفة القائم على التسعير أكبر من الصفر."

msgid "A Pricing Based Cost rate already exists for this date and category. Please use a different date or archive the existing record first."
msgstr "يوجد بالفعل سعر تكلفة لهذا التاريخ والفئة. يرجى استخدام تاريخ مختلف أو أرشفة السجل الحالي أولاً."

msgid "An applied rate already exists for this date and category: %s. Please archive it before applying a new one."
msgstr "يوجد بالفعل سعر مُطبَّق لهذا التاريخ والفئة: %s. يرجى أرشفته قبل تطبيق سعر جديد."

msgid "Category (blank = All)"
msgstr "الفئة (فارغ = الكل)"

msgid "Company"
msgstr "الشركة"

msgid "Global (All Categories)"
msgstr "عام (جميع الفئات)"

msgid "Month"
msgstr "الشهر"

msgid "This will update the Sales Price of all matching area-priced products. Continue?"
msgstr "سيؤدي هذا إلى تحديث سعر البيع لجميع المنتجات المسعَّرة بالمساحة المطابقة. هل تريد المتابعة؟"

msgid "e.g. March 2025 Rate Increase"
msgstr "مثال: زيادة سعر مارس 2025"

msgid "Optional: reason for this rate, supplier reference, etc."
msgstr "اختياري: سبب هذا السعر، مرجع المورد، إلخ."

msgid "Leave empty to apply to ALL categories."
msgstr "اتركه فارغاً للتطبيق على جميع الفئات."

msgid "The active Pricing Based Cost rate at the time this quotation was created."
msgstr "سعر التكلفة القائم على التسعير النشط عند إنشاء عرض الأسعار هذا."

msgid "Save the rate in Draft, then click Apply Rate to update all area-priced product prices. A full before/after log is stored on each applied rate record."
msgstr "احفظ السعر كمسودة، ثم انقر على تطبيق السعر لتحديث أسعار جميع المنتجات المسعَّرة بالمساحة. يتم حفظ سجل كامل قبل/بعد على كل سجل سعر مُطبَّق."

msgid "Refresh all area-priced lines to the current Pricing Based Cost rate."
msgstr "تحديث جميع أسطر المنتجات المسعَّرة بالمساحة وفق سعر التكلفة الحالي."