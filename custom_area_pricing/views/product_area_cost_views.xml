<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ──────────────────────────────────────────────────────── -->
    <record id="view_product_area_cost_list" model="ir.ui.view">
        <field name="name">product.area.cost.list</field>
        <field name="model">product.area.cost</field>
        <field name="arch" type="xml">
            <tree string="Pricing Based Cost Rates"
                  decoration-muted="active == False">
                <field name="name"/>
                <field name="date"/>
                <field name="rate" string="Rate (per m²)"/>
                <field name="currency_id" groups="base.group_multi_currency"/>
                <field name="categ_id" string="Category (blank = All)"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────────────────────────── -->
    <record id="view_product_area_cost_form" model="ir.ui.view">
        <field name="name">product.area.cost.form</field>
        <field name="model">product.area.cost</field>
        <field name="arch" type="xml">
            <form string="Pricing Based Cost Rate">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_preview_update"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-eye"
                                string="Preview Update"
                                help="See which products will be updated before saving."/>
                        <button class="oe_stat_button" icon="fa-tags" type="object" name="action_preview_update">
                            <field string="Products Updated" name="updated_product_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. March 2025 Rate Increase"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Rate Details">
                            <field name="date"/>
                            <field name="rate" string="Pricing Based Cost (per m²)"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Scope">
                            <field name="categ_id"
                                   string="Product Category"
                                   help="Leave empty to apply to ALL categories. A category-specific rate takes priority on the same date."/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Optional: reason for this rate, supplier reference, etc."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ────────────────────────────────────────────────────── -->
    <record id="view_product_area_cost_search" model="ir.ui.view">
        <field name="name">product.area.cost.search</field>
        <field name="model">product.area.cost</field>
        <field name="arch" type="xml">
            <search string="Pricing Based Cost">
                <field name="name"/>
                <field name="categ_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <filter string="Global (All Categories)" name="global"
                        domain="[('categ_id','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_categ"
                            context="{'group_by': 'categ_id'}"/>
                    <filter string="Month" name="group_month"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_product_area_cost" model="ir.actions.act_window">
        <field name="name">Pricing Based Cost</field>
        <field name="res_model">product.area.cost</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_product_area_cost_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Pricing Based Cost rate
            </p>
            <p>
                Define dated cost-per-m² rates. The most recent rate on or before
                the quotation date will be used to compute the sale price.
                Category-specific rates take priority over global rates.
            </p>
        </field>
    </record>

</odoo>
