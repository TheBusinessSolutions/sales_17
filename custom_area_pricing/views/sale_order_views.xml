<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_order_area_pricing" model="ir.ui.view">
        <field name="name">sale.order.area.pricing</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Recalculate button: visible on draft/sent only -->
            <xpath expr="//header/button[@name='action_confirm']" position="before">
                <button name="action_recalculate_area_prices"
                        string="↻ Recalculate Area Prices"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ('draft', 'sent')"
                        help="Refresh all area-priced lines to the current Pricing Based Cost rate."/>
            </xpath>

            <!-- Dimension + rate snapshot columns on order lines -->
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']"
                   position="after">
                <field name="is_area_priced" column_invisible="1"/>
                <field name="area_width"
                       string="W (m)"
                       invisible="not is_area_priced"
                       readonly="state not in ('draft', 'sent')"
                       optional="show"/>
                <field name="area_height"
                       string="H (m)"
                       invisible="not is_area_priced"
                       readonly="state not in ('draft', 'sent')"
                       optional="show"/>
                <field name="area_sqm"
                       string="Area (m²)"
                       invisible="not is_area_priced"
                       optional="show"/>
                <field name="applied_cost_rate"
                       string="Rate/m²"
                       invisible="not is_area_priced"
                       optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>
